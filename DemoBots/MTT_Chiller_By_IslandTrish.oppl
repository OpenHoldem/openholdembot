##f$preflop##
//////////////////////////////////////////////////////////////////////////////////////
// 										Preflop
//////////////////////////////////////////////////////////////////////////////////////

//\\ OverRides \\//

// At the start of pre-flop we use some general overrides
// Add your own here
When TotalInvested > 33% StackSize RaiseMax Force
//Raise sitouts
When Calls = 0 and Raises = 0 And OpponentsLeftSittingOut RaiseMin Force
// Don't fold premiums
When BotsLastAction = Raise And StackSize <= 20 And listCat2 RaiseMax Force
When BotsLastAction = Raise And listCat2 RaisePot Force
// It's over...
When StackSize <= 2 And (ante > 0 Or InTheBlinds) RaiseMax Force
When AmountToCall < 1 And balance_bigstackchair < bblind Raise Force
When Not f$RedZone And Raises > 1 And Not listCat2a Fold Force

//
// Freeroll madness very loose freeroll play \\
// Example of using flag buttons:
// Press F0 to enable f$FreerollHammer at any time or F1 to disable
// If you don't press F1 it will play if the title contains the word free
// You can comment out the line below for FreerollHammer if you never want to use this loose freeroll style


//\\ Main Play \\//
When f$FinalTableSet Return f$FinalTablePlay Force
When f$FreerollHammer And log$FreerollHammer RaiseMax Force
When nplayersseated = 2 And log$HU Return f$Trish_HeadsUp Force
When f$RedZone And log$RedZone Return f$RedZonePlay Force
When f$OrangeZone And log$OrangeZone Return f$OrangeZonePlay Force
When f$YellowZone And log$YellowZone Return f$YellowZonePlay Force
When f$GreenZone And log$GreenZone Return f$GreenZonePlay Force
//
When f$OpponentsExcludingSitOuts <= (1 + CallsSinceLastRaise) And AmountToCall < 1 Call Force
//

##f$flop##
//////////////////////////////////////////////////////////////////////////////////////
// 										Flop
//////////////////////////////////////////////////////////////////////////////////////

// Main post flop play is handled by a tweaked Gecko version
// Check out the Gecko Tweaks section
//
// Flop overrides can be added here
// OverRides are a list of conditions you want to be
// carried out before the Gecko Tweaks section is considered
//
//^^ Including this as an example of using memory symbols ^^\\
When me_re_slowplaypre = 1 And log$SlowPlayPush RaiseMax Force
// Example -- Raise sitouts
When Calls = 0 and Raises = 0 And OpponentsLeftSittingOut Raise Force
// Example -- Call nuts
When prwin+(prtie*0.50) > 0.92 And log$SlowPlay Call Force
// Example -- Short Stack Aggression
When Raises = 0 And prwin+(prtie*0.50) < 0.92 And (HaveBestOverPairOrBetter Or (HaveTopPair And HaveSecondBestKickerOrBetter)) And Not StraightPossibleOnFlop And Not FlushPossible
	When (PotSize * 3) >= StackSize And log$SS_Flop_Play RaiseMax Force
	When ((StackSize < 10) Or f$TheBiggestActiveOpponentsStack <= 8) And log$SS_Flop_Play RaiseMax Force
// No When Others here leave it open unless you add more code below


//
// To edit the main post flop play please use the functions
// in the Gecko Tweaks section below
//
// Please do not modify the original Gecko logic


##f$turn##
//////////////////////////////////////////////////////////////////////////////////////
// 										Turn
//////////////////////////////////////////////////////////////////////////////////////

// Main post flop play is handled by a tweaked Gecko version
// Check out the Gecko Tweaks section
//
// Turn overrides can be added here
// OverRides are a list of conditions you want to be
// carried out before the Gecko Tweaks section is considered
//
// Example -- Raise sitouts
When Calls = 0 and Raises = 0 And OpponentsLeftSittingOut Raise Force
// Example -- Call nuts
When prwin+(prtie*0.50) > 0.94 And log$SlowPlay Call Force


//	
// To edit the main post flop play please use the functions
// in the Gecko Tweaks section below
//
// Please do not modify the original Gecko logic


##f$river##
//////////////////////////////////////////////////////////////////////////////////////
// 										River
//////////////////////////////////////////////////////////////////////////////////////

// Main post flop play is handled by a tweaked Gecko version
// Check out the Gecko Tweaks section
//
// River overrides can be added here
// OverRides are a list of conditions you want to be
// carried out before the Gecko Tweaks section is considered
//
// Example -- Raise sitouts
When Calls = 0 and Raises = 0 And OpponentsLeftSittingOut Raise Force


//	
// To edit the main post flop play please use the functions
// in the Gecko Tweaks section below
//
// Please do not modify the original Gecko logic


##f$Trish_HeadsUp##
//////////////////////////////////////////////////////////////////////////////////////
// 										Heads Up
//////////////////////////////////////////////////////////////////////////////////////
// A basic HU
//
//  Introducing a sliding exponential ShortStack Strategy
When f$HandRank2Way <= (2652*f$SS_Blind_HU_Log) RaiseMax Force

When InSmallBlind
   When BotsLastAction = Raise And f$Stack_12P And listHUCat1 RaiseMax Force
   When BotsLastAction = Raise And f$Stack_12P And listHUCat5 Call Force
   When f$FirstAction And f$Stack_12P And listHUCat8 RaiseBy 3 Force
   When f$Stack_8_12 And listHUCat8 RaiseMax Force

When InBigBlind
   When BotsLastAction = Raise And f$Stack_12P And listHUCat1 RaiseMax Force
   When BotsLastAction = Raise And f$Stack_12P And listHUCat4 Call Force
   When f$FirstAction And f$Stack_12P And Raises = 0 And listHUCat6 RaiseBy 3 Force
   When f$Stack_8_12 And Raises = 0 And listHUCat7 RaiseMax Force 

When InBigBlind And f$FirstAction And Raises = 1
   When f$Stack_12P And AmountToCall > 3 And listHUCat5 RaiseMax Force
   When f$Stack_12P And AmountToCall <= 3 And listHUCat5 RaiseBy (4 * AmountToCall) Force
   When f$Stack_12P And AmountToCall <= 3 And listHUCat7 Call Force
   When f$Stack_4_12 And listHUCat6 RaiseMax Force
   When f$Stack_2_4 And listHUCat7 RaiseMax Force
   
When Others
	When Others Fold Force
	

##f$RedZonePlay##
//////////////////////////////////////////////////////////////////////////////////////
// 										Red Zone ShortStack
//////////////////////////////////////////////////////////////////////////////////////

// I use a list based solution here ^BUT^
// a simple sliding exponential ShortStack Strategy as in HU could be used instead

//^^ Including this as an example of using memory symbols ^^\\
When Not f$FirstAction  And me_re_slowplaypre = 1  And log$SlowPlayPrePush RaiseMax Force
When f$SlowPlayPremiumsSet !=1 And log$SlowPlayPre Return f$SlowPlayPremiums Force
////////////////////////////////////////////////////////////\\

When listCat2 RaiseMax Force
When Not f$FirstAction And currentbet > bblind RaiseMax Force

// If ShortStack and < 10bb we now use ICM push or fold...
// Example of using Weighted Prwin with ICM
When f$ICM_BootCamp_Push RaiseMax Force
When f$ICM_BootCamp_Call RaiseMax Force
//
When f$FirstAction And f$HandRank2Way < (2652*f$Trish_SS_Log) RaiseMax Force

// \\ Shortstack Repush \\ //

// Not in a blind \\
When Raises <= 1 And f$FirstAction And Not InTheBlinds
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPnotblindEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 8 And listRPnotblindEP8 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPnotblindMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 9 And listRPnotblindMP9 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPnotblindMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4  And StackSize <= 5 And listRPnotblindMP5 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.15) RaiseMax Force
	When LastRaiserPosition <= 3 And listRPnotblindCO13 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 11 And listRPnotblindCO11 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 9 And listRPnotblindCO9 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 7 And listRPnotblindCO7 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 6 And listRPnotblindCO6 RaiseMax Force

// In small blind \\
When Raises <= 1 And f$FirstAction And InSmallBlind
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPsbEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 8 And listRPsbEP9 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPsbMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 7 And listRPsbMP7 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPsbMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 4 And listRPsbMP4 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And CallsSinceLastRaise = 0 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.22) RaiseMax Force
	When LastRaiserPosition = 3 And listRPsbCO13 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 11 And listRPsbCO11 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 8 And listRPsbCO8 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 5 And listRPsbCO5 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 4 And listRPsbCO4 RaiseMax Force
	// Vs BU 
	When LastRaiserPosition <= 2 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.28) RaiseMax Force
	When LastRaiserPosition <= 2 And listRPsbBU13 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 10 And listRPsbBU10 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 8 And listRPsbBU8 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 6 And listRPsbBU6 RaiseMax Force

// In Big blind \\
When Raises <= 1 And f$FirstAction And InBigBlind
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPbbEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 10 And listRPbbEP10 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPbbMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 8 And listRPbbMP8 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 7 And listRPbbMP7 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPbbMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 5 And listRPbbMP5 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 4 And listRPbbMP4 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 3 And listRPbbMP3 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 2 And listRPbbMP2 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And CallsSinceLastRaise = 0 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.22) RaiseMax Force
	When LastRaiserPosition = 3 And listRPbbCO13 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 10 And listRPbbCO10 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 8 And listRPbbCO8 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 6 And listRPbbCO6 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 5 And listRPbbCO5 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 4 And listRPbbCO4 RaiseMax Force
	// Vs BU 
	When LastRaiserPosition <= 2 And CallsSinceLastRaise = 0 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.28) RaiseMax Force
	When LastRaiserPosition = 2 And listRPsbBU13 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 10 And listRPbbBU10 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 8 And listRPbbBU8 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 6 And listRPbbBU6 RaiseMax Force
	// Vs SB 
	When LastRaiserPosition <= 1 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.36) RaiseMax Force
	When LastRaiserPosition <= 1 And listRPbbSB13 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 10 And listRPbbSB10 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 8 And listRPbbSB8 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 7 And listRPbbSB7 RaiseMax Force

When Others
	When Others Fold Force


##f$OrangeZonePlay##
//////////////////////////////////////////////////////////////////////////////////////
// 										Orange Zone
//////////////////////////////////////////////////////////////////////////////////////


// The Orange Zone is push or fold but not as drastic as the Red Zone
// Ideally you want to be first in and never call raises
// When we play vs open limped hands we push, but you can change that below
//
//No Second Actions needed as we just open push or fold
//

When listCat2a RaiseMax Force
When Not f$FirstAction And currentbet > bblind RaiseMax Force

// Calling all-ins with premium hands
// An over cautious example you need to change this...
When f$OpponentSignificantAllin And f$FirstAction
	When listCat1 And (CallsSinceLastRaise > 0 Or Raises > 1) RaiseMax Force
	When listCat2 And Raises <= 1 RaiseMax Force
	// Get out of the multi-way all in unless very short stacked 
	When (CallsSinceLastRaise > 1 Or Raises > 1) Fold Force
	When listCat5 And StackSize <= 14 RaiseMax Force
	When StackSize > 12 Fold Force
When Others

When f$FirstAction
// Basic 3Bet \\ You should improve this
   When f$BootCamp3Bet != 0 And log$Orange_3Bet Return f$BootCamp3Bet Force
   When f$HandRank2Way < (2652*f$Trish_SS_Log) RaiseMax Force

When Others
	When Others Fold Force
	


##f$YellowZonePlay##
//////////////////////////////////////////////////////////////////////////////////////
// 										Yellow Zone
//////////////////////////////////////////////////////////////////////////////////////
//
//The Yellow zone is similar to the Green zone but more aggressive
// Ideally we should raise more and call speculatively less ^^BUT^^
// I am just writing this quickly as a get you going starter

// Second Actions
// Very basic starter you need to work on this...
When Not f$FirstAction And listCat2 RaiseMax Force
When BotsLastAction = Raise And listCat3 RaisePot Force

// A short stack is attempting a re-steal
When BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 6 RaiseMax Force
When BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 8 And f$HandRank2Way < (2652*0.180) RaiseMax Force
When BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 12.5 And f$HandRank2Way < (2652*0.155) RaiseMax Force


When BotsLastAction = Raise And f$HandRank_Playability_General < (2652*0.09) And AmountToCall <= 15% StackSize Call Force
When BotsLastAction = Raise And AmountToCall <= 6% StackSize Call Force
When BotsLastAction = Raise And listCat4 And AmountToCall <= 50% StackSize And Opponents <= (1 + CallsSinceLastRaise) Call Force
When (BotsLastAction = Raise Or BotsLastAction = Call) And AmountToCall <= 2.5 Call Force
When BotsLastAction = Raise Fold Force

// Calling all-ins with premium hands
// An over cautious example you need to change this...
When f$OpponentSignificantAllin And f$FirstAction
	When listCat1 And (CallsSinceLastRaise > 0 Or Raises > 1) RaiseMax Force
	When listCat2 And Raises <= 1 RaisePot Force
	// Get out of the multi-way all in unless very short stacked 
	When (CallsSinceLastRaise > 1 Or Raises > 1) Fold Force
	When listCat5 And AmountToCall <= 5 RaisePot Force
	When listCat5 And AmountToCall < (StackSize * 0.125) Call Force
	When StackSize > 12 Fold Force
When Others

When f$FirstAction
// Basic 3Bet \\ You should improve this
   When f$BootCamp3Bet != 0 And log$Yellow_3Bet Return f$BootCamp3Bet Force
 
// Opening and raising limpers again over simple
// You can replace handrank with lists as you wish
// Or change the percentages for more tight or loose
// 0.125 is 12.5% -- 0.330 is 33% 

When f$FirstAction and Raises = 0 && f$ShortStacksPlaying > 0 
	When InEarlyPosition1 And f$HandRank2Way < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank2Way < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank2Way < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank2Way < (2652 * 0.180) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank2Way < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank2Way < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank2Way < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank2Way < (2652 * 0.180) RaiseTo (2.5 + Calls) Force
When f$FirstAction And Raises = 0 And Calls = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo 3 Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.105) RaiseTo 3 Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.110) RaiseTo 3 Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo 3 Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo 3 Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo 2.5 Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.230) RaiseTo 2.5 Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.360) Raise Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.330) RaiseTo 2.5 Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo 3 Force	
	
When f$FirstAction And  Raises = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
When Others

// Calling and limping if we have not raised
// Improved from last version but still needs work

When f$FirstAction And AmountToCall > 2
	// Fold hands you don't want to play multiway raised
	//	It is covered above but just in case you delete that
	//	change the list for your own style
	When Raises > 1 And Not listCat2 Fold Force
	// Fold hands you don't want to play in large pots
	//	change the lists and BetSize for your own style
	when BetSize > 8 And Not listCat2 Fold Force
	When BetSize > 5 And Not listCallTight Fold Force
 
When f$FirstAction And InSmallBlind 
	// Call standard raises 
	//	Change the list and BetSize for your own style
	When BetSize < 4.5 And Calls > 1 And listCallSB Call Force
	When BetSize < 4.5 And (Calls > 0 Or Raises = 1) And listCallSBA Call Force
	// Hands you would open limp
	When (Calls + Raises = 0) And listLimpStd Call Force

When f$FirstAction And InLatePosition 
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 4.5 And FirstRaiserPosition >= 5 And listCallMedium Call Force
	When BetSize < 4.5 And FirstRaiserPosition < 5 And (Calls > 0 Or Raises = 1) And listCallLoose Call Force
	// Hands you would open limp, *Repetition* BUT
	// A different list could be used here than in above SB
	When (Calls + Raises = 0) And listLimpStd Call Force
	
// When f$FirstAction And InMiddlePosition
	// 	A block for middle positions could be added here if you like
	
When f$FirstAction And (InEarlyPosition Or InMiddlePosition)
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 4.5 And (Calls > 0 Or Raises = 1) And listCallMedium Call Force
	// Hands you would open limp, *Repetition* BUT
	// A different list could be used here than in above SB or late positions
	When (Calls + Raises = 0) And listLimpMid Call Force
	
When f$FirstAction And InBigBlind And AmountToCall > 0
	// AmountToCall not needed in above line but it short-cuts 
	//	reading the next 3 lines for unopened pots	
	When BetSize < 4.5 And listCallMedium Call Force
	When BetSize < 2.4 And listCallBBA Call Force
	When BetSize < 1.4 And listCallBB Call Force
When Others

When Others Fold Force


##f$GreenZonePlay##
//////////////////////////////////////////////////////////////////////////////////////
// 										Green Zone
//////////////////////////////////////////////////////////////////////////////////////

// In the Green zone we can play any way we like we can be tight or loose 
// This is just a get you going example

// Second Actions
// Very basic you need to work on this...
When Not f$FirstAction And listCat2 RaisePot Force
// A short stack is attempting a re-steal
When BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 8 RaiseMax Force
When BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 12.5 And f$HandRank2Way < (2652*0.125) RaiseMax Force
When BotsLastAction = Raise And listCat3 RaisePot Force
When BotsLastAction = Raise And f$HandRank_Playability_General < (2652*0.09) And AmountToCall <= 15% StackSize Call Force
When BotsLastAction = Raise And listCat4 And AmountToCall <= 50% StackSize And Opponents <= (1 + CallsSinceLastRaise) Call Force
When (BotsLastAction = Raise Or BotsLastAction = Call) And AmountToCall <= 2.5 Call Force
When BotsLastAction = Raise Fold Force

// Calling all-ins with premium hands
// An over cautious example you need to change this...
When f$OpponentSignificantAllin And f$FirstAction
	When listCat1 And Raises > 1 RaiseMax Force
	When listCat2 And Raises <= 1 RaisePot Force
	// Get out of the multi-way all in unless very short stacked 
	When (CallsSinceLastRaise > 1 Or Raises > 1) Fold Force
	When listCat5 And AmountToCall <= 5 RaisePot Force
	When listCat5 And AmountToCall < (StackSize * 0.125) Call Force
	When StackSize > 12 Fold Force
When Others

When f$FirstAction
// Basic 3Bet \\ You should improve this
   When f$BootCamp3Bet != 0 And log$Green_3Bet Return f$BootCamp3Bet Force
 
// Opening and raising limpers again over simple
// You can replace handrank with lists as you wish
// Or change the percentages for more tight or loose
// 0.125 is 12.5% -- 0.330 is 33% 

When f$FirstAction and Raises = 0 && f$ShortStacksPlaying > 0 
	When InEarlyPosition1 And f$HandRank2Way < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank2Way < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank2Way < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank2Way < (2652 * 0.155) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank2Way < (2652 * 0.155) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank2Way < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank2Way < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank2Way < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
When f$FirstAction And Raises = 0 And Calls = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo 3 Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.105) RaiseTo 3 Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.108) RaiseTo 3 Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.110) RaiseTo 3 Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo 3 Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo 2.5 Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.230) RaiseTo 2.5 Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.330) Raise Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.330) RaiseTo 2.5 Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.180) RaiseTo 3 Force	
	
When f$FirstAction And  Raises = 0 And Calls = 1
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
	
When f$FirstAction And  Raises = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.180) RaiseTo (2.5 + Calls) Force
When Others

// Calling and limping if we have not raised
// Improved from last version but still needs work

When f$FirstAction And AmountToCall > 2
	// Fold hands you don't want to play multiway raised
	//	It is covered above but just in case you delete that
	//	change the list for your own style
	When Raises > 1 And Not listCat2 Fold Force
	// Fold hands you don't want to play in large pots
	//	change the lists and BetSize for your own style
	when BetSize > 8 And Not listCat2 Fold Force
	When BetSize > 5 And Not listCallTight Fold Force
 
When f$FirstAction And InSmallBlind 
	// Call standard raises 
	//	Change the list and BetSize for your own style
	When BetSize < 4.5 And Calls > 1 And listCallSB Call Force
	When BetSize < 4.5 And (Calls > 0 Or Raises = 1) And listCallSBA Call Force
	// Hands you would open limp
	When (Calls + Raises = 0) And listLimpLoose Call Force

When f$FirstAction And (InLatePosition Or InMiddlePosition3)
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 4.5 And FirstRaiserPosition >= 6 And listCallMedium Call Force
	When BetSize < 4.5 And FirstRaiserPosition < 6 And (Calls > 0 Or Raises = 1) And listCallLoose Call Force
	When BetSize < 4.5 And FirstRaiserPosition < 6 And (Calls + Raises > 1) And CallsSinceLastRaise = 0 And listCallVeryLoose Call Force
	When BetSize < 4.5 And Raises = 0 And Calls > 2 And listCallVeryLoose Call Force
	// Hands you would open limp, *Repetition* BUT
	// A different list could be used here than in above SB
	When (Calls + Raises = 0) And listLimpLoose Call Force
	
// When f$FirstAction And InMiddlePosition
	// 	A block for middle positions could be added here if you like
	
When f$FirstAction And (InEarlyPosition Or InMiddlePosition)
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 4.5 And (Calls > 0 Or Raises = 1) And listCallMedium Call Force
	// Hands you would open limp, *Repetition* BUT
	// A different list could be used here than in above SB or late positions
	When (Calls + Raises = 0) And listLimpMid Call Force
	
When f$FirstAction And InBigBlind And AmountToCall > 0
	// AmountToCall not needed in above line but it short-cuts 
	//	reading the next 3 lines for unopened pots	
	When BetSize < 4.5 And listCallMedium Call Force
	When BetSize < 2.4 And listCallBBA Call Force
	When BetSize < 1.4 And listCallBB Call Force
When Others

When Others Fold Force
//////////////////////////////////////////////////

##f$SlowPlayPremiums##
//^^ Including this as an example of using memory symbols ^^\\
When (hand$AA Or hand$KK) And StackSize <= 11
	When BetSize > 2 And Opponents > (1 + CallsSinceLastRaise) Return false Force
	when (StackSize - AmountToCall) < 5 Return false Force
	When Raises > 1 Return false Force
	When Raises = 1 And CallsSinceLastRaise > 1 Return false Force
	When Raises = 1 And CallsSinceLastRaise = 1 And Calls > (CallsSinceLastRaise + 1) Return false Force
	When Raises = 1 Or (InButton Or InCutOff) Call Force
	When Others Raise Force

##f$SlowPlayPremiumsSet##	
When f$SlowPlayPremiums != 0 Return me_st_slowplaypre_1 Force
When Others Return 1 Force
	 
##f$ini_function_on_handreset##
me_st_slowplaypre_0
+ me_st_raisesbeforeuspf_0
+ me_st_greenzoneset_0
+ me_st_yellowzoneset_0
+ me_st_orangezoneset_0

##f$ini_function_on_my_turn##
betround = 1 And me_st_raisesbeforeuspf_f$RaisesBeforeFirstActionPreflopCalc

##f$RaisesBeforeFirstActionPreFlop##
// Included as an example of memory symbols
me_re_raisesbeforeuspf

##f$RaisesBeforeFirstActionPreflopCalc##
When betround = 1 And BotsLastAction = None And (Raises + Bets) >= 1 Return (Raises + Bets) FORCE
When Others Return me_re_raisesbeforeuspf Force


##f$prefold##
// Adding this function to stop Gecko's as it doesn't suit this preflop
// Add conditions for when you want to prefold
// EXAMPLE
When Random < 10 Return false Force
When IsPostflop RETURN false Force
When (call < 0.01) Return false Force
When (InUTG Or InEarlyPosition2) Return false Force
When InEarlyPosition3 And Random < 45 Return false Force
When nplayersdealt <= 3 Return false Force
When Calls = 0 And Raises = 0 And balance_bigblindchair <= (bblind*2) Return false Force
When (BigBlindSittingOut Or StackSize <= 4) Return false Force
When StackSize > 12 And listbad Return true Force
When listverybad Return true Force

##f$TheBiggestActiveOpponentsChips##
balance_bigstackchair + currentbet_bigstackchair

##f$TheBiggestActiveOpponentsStack##
f$TheBiggestActiveOpponentsChips / bblind

##f$EffectiveActiveStackInBigBlinds##
balance + currentbet < f$TheBiggestActiveOpponentsChips ? (balance + currentbet) / bblind :
f$TheBiggestActiveOpponentsStack

##f$reducewinchance_when_have_twopair##
// This is used in combination with f$threat 
// It reduces our f$prwin when we have two pair and one is a board pair
// Modified from original Gecko to disable it if a board pair is lower than 
// 	our two pair, as in this case the board pair does not contribute to our hand
When TwoPairOnBoard Return false Force
When nrankedcommon > 2 Return false Force // Trips or quads on board
When nplayersround_flop < 3 Return false Force // Hand went HU Preflop
When Not PairOnBoard Return false Force
When trankcommon < rankloplayer Return false Force // Board pair is lower than both our pairs
When istwopair AND trankcommon > 7 Return 0.400  Force // Board pair must be 88 or better
// 
// I am including this for the time being, it may be improved later in Gecko itself
// http://www.maxinmontreal.com/forums/viewtopic.php?f=184&t=21070&start=540#p166612

##f$BestBetsize##
// A tweak to Gecko's original to push rather than standard raise
// if we are effectively short stacked
// Consider changing 10 here perhaps 12?
When f$EffectiveActiveStackInBigBlinds <= 10 RaiseMax force
WHEN IsPreflop RETURN f$BetsizePreflop FORCE
WHEN HandIsHeadsup
   WHEN IsFlop  RETURN f$BetsizeFlopHeadsup  FORCE
   WHEN IsTurn  RETURN f$BetsizeTurnHeadsup  FORCE
   WHEN IsRiver RETURN f$BetsizeRiverHeadsup FORCE
WHEN Others
   WHEN IsFlop  RETURN f$BetsizeFlopMultiway  FORCE
   WHEN IsTurn  RETURN f$BetsizeTurnMultiway  FORCE
   WHEN IsRiver RETURN f$BetsizeRiverMultiway FORCE
   
##f$BetsizeFlopHeadsup##
WHEN (AmountToCall <= 1)
   WHEN (nbetsround_preflop <= 6)  RaiseBy 66% FORCE
   WHEN Others  RaiseBy 55% FORCE
WHEN NOT didbetsize
   WHEN (AmountToCall <= 33% PotSize) RaisePot FORCE
   WHEN Others RaiseBy (2 * BetSize) FORCE
WHEN Others
   WHEN (nbetsround_preflop <= 1) RaiseBy (2 * BetSize) FORCE
   WHEN f$ptype_raise_contibet_very_high RaiseBy (2 * BetSize) FORCE
   // Formerly RaiseMax.
   WHEN Others RaisePot FORCE
           
##f$BetsizeTurnHeadsup##
WHEN (AmountToCall <= 0)
   WHEN (PotSize <= 35) RaiseBy 66% FORCE
   WHEN Others RaisePot FORCE
WHEN (AmountToCall <= 2)
   WHEN (PotSize <= 25) RaisePot FORCE
   WHEN Others RaiseBy 66% FORCE
WHEN Others
   // Formerly RaiseMax.
   WHEN f$betline RaisePot FORCE
   WHEN (AmountToCall <= 33% PotSize) RaisePot FORCE
   WHEN Others RaiseBy (4 * BetSize) FORCE

##f$BetsizeRiverHeadsup##
WHEN (AmountToCall <= 0)
   WHEN (PotSize <= 10) RaiseBy 66% FORCE
   // Huge pot, don't blow money away.
   // Make betsize dependent on prwin.
   // Block-bet with not so strong hands
   WHEN (f$prwin<=0.8) RaiseBy 25% FORCE
   WHEN Others RaiseBy 60% FORCE   
WHEN (AmountToCall <= 1.5) RaisePot FORCE
WHEN Others
   WHEN (AmountToCall <= 33% PotSize) RaisePot FORCE
   WHEN Others RaiseBy (3 * BetSize) FORCE

##f$BetsizeFlopMultiway##
// Gecko had here 60% / 62%,
// which is pointless due to rounding
WHEN (AmountToCall <= 1) RaiseBy 60% FORCE
WHEN [ NOT didbetsize ] 
   WHEN (AmountToCall <= 33% PotSize) RaiseBy 66% FORCE
   WHEN Others RaiseBy (4 * BetSize) FORCE
WHEN Others
   WHEN (nbetsround_preflop<=1) RaiseBy (4 * BetSize) FORCE
   // Preflop raised, flop reraised.
   // Lots of action, large pot.
   // Formerly RaiseMax.
   WHEN Others RaisePot FORCE

##f$BetsizeTurnMultiway##
WHEN (AmountToCall <= 1)
   WHEN (PotSize <= 10) RaiseBy 66% FORCE
   WHEN Others RaiseBy 60% FORCE
WHEN Others
   WHEN (AmountToCall <= 33% PotSize) RaisePot FORCE
   WHEN Others RaiseBy (4 * BetSize) FORCE

##f$BetsizeRiverMultiway##
WHEN AmountToCall <= 1
   WHEN (PotSize <= 10) RaisePot FORCE
   WHEN Others RaiseBy 60% FORCE
WHEN Others
   WHEN (AmountToCall <= 33% PotSize) RaisePot FORCE
   WHEN Others RaiseBy (4 * BetSize) FORCE


##f$Stack_0_2##  
// Stack Sizes \\
// EffectiveMaxStacksizeOfActiveOpponents wont work for these, if an opponent is all-in 
	// say with 14BB and you have 12BB it will return 0 as it does not include current bets 
	// added a user function f$EffectiveActiveStackInBigBlinds
When f$EffectiveActiveStackInBigBlinds < 2 Return true Force

##f$Stack_0_4##
When (f$EffectiveActiveStackInBigBlinds <= 4) RETURN true Force

##f$Stack_0_5##
When f$EffectiveActiveStackInBigBlinds < 5 Return true Force

##f$Stack_0_8##
When (f$EffectiveActiveStackInBigBlinds <= 8) RETURN true Force

##f$Stack_0_12##
When (f$EffectiveActiveStackInBigBlinds <= 12) RETURN true Force

##f$Stack_2_4##
When (f$EffectiveActiveStackInBigBlinds > 4) RETURN false Force
When (f$EffectiveActiveStackInBigBlinds <= 2) RETURN false Force
When Others RETURN true Force

##f$Stack_2_8##
When (f$EffectiveActiveStackInBigBlinds > 8) RETURN false Force
When (f$EffectiveActiveStackInBigBlinds <= 2) RETURN false Force
When Others RETURN true Force

##f$Stack_4_12##
When (f$EffectiveActiveStackInBigBlinds > 12) RETURN false Force
When (f$EffectiveActiveStackInBigBlinds <= 4) RETURN false Force
When Others RETURN true Force

##f$Stack_5_12##
When (f$EffectiveActiveStackInBigBlinds >= 5 And f$EffectiveActiveStackInBigBlinds < 12) Return true Force

##f$Stack_8_12##
When (f$EffectiveActiveStackInBigBlinds > 12) RETURN false Force
When (f$EffectiveActiveStackInBigBlinds <= 8) RETURN false Force
When Others RETURN true Force

##f$Stack_12P##
When f$EffectiveActiveStackInBigBlinds >= 12 Return true Force

##f$Stack_14_P##
When (f$EffectiveActiveStackInBigBlinds >= 14) RETURN true Force

##f$OpponentSignificantAllin##
When OpponentIsAllin
	When InBigBlind And AmountToCall >= 2 Return true Force
	When InSmallBlind And AmountToCall >= 2.5 Return true Force
	When AmountToCall >= 3 Return true Force

##f$FirstAction##
When BotsLastAction = None Return true Force 

##f$prwin_mustplay##
// Weighted Prwin the numbers are handrank169
// Absolute premium-hands, that will never be folded by your opponent
betround != 1 ? 0 :
StackSize > 10 ? 0 :
3

##f$prwin_topclip##
// Weighted Prwin the numbers are handrank169
// The top of your opponents range, which will be played with certainty
betround != 1 ? 0 :
StackSize > 10 ? 0 :
4

##f$prwin_willplay##
// Weighted Prwin the numbers are handrank169
// The bottom of your opponents range, which will be played with certainty
betround != 1 ? 0 :
StackSize > 10 ? 0 :
46

##f$prwin_wontplay##
// Weighted Prwin the numbers are handrank169
// Hands rated lower will never be played by your opponent
betround != 1 ? 0 :
StackSize > 10 ? 0 :
Raises > 0 ? 53 :
BotsLastAction = Raise ? 56 :
116

##f$ICM_ProbCalledCalc##
// ICM Starts here
// Over Simple \\ Similar to the Manual example
f$EffectiveActiveStackInBigBlinds > 18 ? 0.90 :
f$EffectiveActiveStackInBigBlinds > 15 ? 0.85 :
f$EffectiveActiveStackInBigBlinds > 10 ? 0.80 :
f$EffectiveActiveStackInBigBlinds > 8 ? 0.70 :
f$EffectiveActiveStackInBigBlinds > 6 ? 0.60 :
0.65

##f$ICM_ProbCalled##
f$OpponentsExcludingSitOuts = 9 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 8 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 7 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 6 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 5 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 4 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 3 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 2 ? 1 - (f$ICM_ProbCalledCalc*f$ICM_ProbCalledCalc) :
f$OpponentsExcludingSitOuts = 1 ? 1 - f$ICM_ProbCalledCalc :
1

##f$ICM_CalledAndLose##
((1 * f$ICM_ProbCalled) * (1 - (prwin + (prtie*0.50)))) * icm_allilose1

##f$ICM_CalledAndWin##
((1 * f$ICM_ProbCalled) * (prwin + (prtie*0.50))) * icm_alliwin1

##f$ICM_NotCalled##
1 * (1-f$ICM_ProbCalled) * icm_alliwin0


##f$ICM_BootCamp_Push##
f$FinalTableSet And StackSize > 8 ? 0 :
StackSize > 10 ? 0 : // Only if we are less than 10bb \\ Effective and higher handled in main short stack script
(Raises + Calls) > 0 ? 0 : // Only if we open push \\ limped pots handled with our main short stack script
StackSize > 5 And f$HandRank2Way > (2652*0.72) ? 0 : // Sets a cap at 72% of hands 
f$HandRank2Way > (2652*0.76) ? 0 : // Sets a higher cap at 76% of hands if very short
(f$ICM_CalledAndLose + f$ICM_CalledAndWin + f$ICM_NotCalled) > icm_fold ? 1 :
0

##f$ICM_CallWeWin##
(prwin + (prtie*0.50)) * icm_callwin

##f$ICM_CallWeLose##
(1 - (prwin + (prtie*0.50))) * icm_calllose

##f$ICM_BootCamp_Call##
f$FinalTableSet And StackSize > 8 ? 0 :
StackSize > 10 ? 0 : // Only if we are less than 10bb \\ Effective and higher handled in main short stack script
f$OpponentsExcludingSitOuts > 1 And StackSize >= 3 And f$HandRank2Way > (2652*0.167) ? 0 : 
StackSize > 4 And f$HandRank2Way > (2652*0.230) ? 0 : // Sets a cap at 23% of hands 
f$HandRank2Way > (2652*0.300) ? 0 : // Sets a higher cap at 30% of hands if very short
StackSize > 4 And Raises > 1 ? 0 : // Avoid multi raised unless very short
StackSize > 4 And CallsSinceLastRaise > 0 ? 0 : // Avoid multi all-in unless very short
Raises = 0 ? 0 : // Only if there is a raise
(f$ICM_CallWeWin + f$ICM_CallWeLose) > icm_fold ? 1 :
0

##f$Mzone##
balance / (bblind + sblind + (ante*nplayersseated))

//##f$EffectiveMzone##
// Standard Harrington // Comment out whichever you prefer
// 
// Based on table size // TM should be specific for game type \\
// (balance / ((bblind + sblind) + (ante*nplayersseated))) * (nplayersseated/nchairs)

##f$EffectiveMzone##
// My version // Comment out whichever you prefer 
//
((f$EffectiveActiveStackInBigBlinds * bblind) / (bblind + sblind + (ante*nplayersseated))) * (nplayersseated/nchairs)

##f$GreenZone##
me_re_greenzoneset = 1 ? 1 :
f$EffectiveMzone >= 18 And me_st_greenzoneset_1 >= 0 ? 1 :
0

##f$YellowZone##
f$GreenZone ? 0 :
me_re_yellowzoneset = 1 ? 1 :
f$EffectiveMzone < 18 And f$EffectiveMzone >= 10 And me_st_yellowzoneset_1 >= 0 ? 1 :
0

##f$OrangeZone##
f$GreenZone Or f$YellowZone ? 0 :
me_re_orangezoneset = 1 ? 1 :
f$EffectiveMzone < 10 And f$EffectiveMzone >= 6 And me_st_orangezoneset_1 >= 0 ? 1 :
0

##f$RedZone##
f$GreenZone Or f$YellowZone Or f$OrangeZone ? 0 :
f$EffectiveMzone < 6 


##f$SS_Blind_HU_Start##
///////////////////////////////////////////////////////////////////
// Provides a mild exponential increase as the stack diminishes  //
// Using log natural (ln) (e) 2.718281828459 but any base can be used //
///////////////////////////////////////////////////////////////////
InSmallBlind ? 39 :
InBigBlind ? 33 :
33

##f$SS_Blind_HU_Exponent##
(ln (75 / f$SS_Blind_HU_Start) / 6)*(8-f$EffectiveActiveStackInBigBlinds)

##f$SS_Blind_HU_Log##
f$EffectiveActiveStackInBigBlinds > 8 ? 0 :
f$SS_Blind_HU_Start*(2.718281828459**(f$SS_Blind_HU_Exponent)) < f$SS_Blind_HU_Start ? (f$SS_Blind_HU_Start/100) :
f$SS_Blind_HU_Start*(2.718281828459**(f$SS_Blind_HU_Exponent)) > 75 ? (0.75) :
f$SS_Blind_HU_Start*(2.718281828459**(f$SS_Blind_HU_Exponent))/100

##f$3BetSizeAdjust##
When betposition < betpositionrais RaiseTo ((4 * BetSize)+ Calls) FORCE //  OOP
When betposition > betpositionrais RaiseTo ((3 * BetSize) + Calls) FORCE // In Position

##f$3BetSize##
// Push if post flop play not viable
When f$EffectiveMzone < 10 RaiseMax Force
When StackSize < (f$3BetSizeAdjust * 3.05) RaiseMax FORCE
When f$EffectiveActiveStackInBigBlinds < ((f$3BetSizeAdjust-BetSize) * 3.05) RaiseMax FORCE
// Positional 3Bet
When Others RaiseTo f$3BetSizeAdjust FORCE

##f$BootCamp3Bet##
// Basic 3Bet \\ You could improve this
	// Hints to improve
	// Consider; calls before the raise, calls since, 
	// if you are BB and closing action
	// Your position, how many left to act
	// More advanced consider; stack size of raiser is he committed? 
	// Consider Other stacks
When (hand$AA Or hand$KK Or hand$QQ Or hand$AKsuited) RaisePot Force
When Raises = 0 Return false Force
When Not f$FirstAction Return false Force 
When Raises > 1 And Not listCat2 Return false Force

// Fold hands you wont play in large pots -- Modify for your style
// Beginner hint:
// Important if you modify don't use Fold Force in here use Return false Force
When BetSize > 5 And f$HandRange3Bet > (2652*0.098) Return false Force
When BetSize > 8 And f$HandRange3Bet > (2652*0.084) Return false Force
// Squeeze
When CallsSinceLastRaise > 0 And f$HandRange3Bet < (2652*0.10) Return f$3BetSize Force
When CallsSinceLastRaise > 0 Return false Force

// Calls before raise
When Calls > 0 And f$HandRange3Bet > (2652*0.180) Return false Force

//
When LastRaiserPosition = 9 And f$HandRange3Bet < (2652*0.060) Return f$3BetSize Force
When LastRaiserPosition = 8 And f$HandRange3Bet < (2652*0.060) Return f$3BetSize Force
When LastRaiserPosition = 7 And f$HandRange3Bet < (2652*0.077) Return f$3BetSize Force
When LastRaiserPosition = 6 And f$HandRange3Bet < (2652*0.083) Return f$3BetSize Force
When LastRaiserPosition = 5 And f$HandRange3Bet < (2652*0.097) Return f$3BetSize Force
When LastRaiserPosition = 4 And f$HandRange3Bet < (2652*0.120) Return f$3BetSize Force
When LastRaiserPosition = 3 And f$HandRange3Bet < (2652*0.160) Return f$3BetSize Force
When LastRaiserPosition = 2 And f$HandRange3Bet < (2652*0.196) Return f$3BetSize Force
When LastRaiserPosition = 1 And f$HandRange3Bet < (2652*0.280) Return f$3BetSize Force

##f$IsFreeRoll##
When (title$Freebuy Or title$FreeBuy Or title$freebuy Or title$FREEBUY Or title$freez Or title$Freez Or title$FREEZ) Return false Force
When (title$Free Or title$free Or title$FREE) Return true Force


##f$FreerollHammer##
When (f$IsFreeRoll Or f0) And Not f1
	When f$HandRank2Way < (2652*0.070) Return true Force
	When f$EffectiveMzone <= 10 And f$HandRank2Way < (2652*0.103) Return true Force
	When Raises = 0 And balance < balanceatstartofsession*1.5 And f$HandRank2Way < (2652*0.195) Return true Force
	When Raises = 0 And f$EffectiveMzone <= 8 And f$HandRank2Way < (2652*0.23) Return true Force
	When Not (InEarlyPosition Or InMiddlePosition1 Or InMiddlePosition2) And Raises = 0 And f$EffectiveMzone <= 10 And f$HandRank2Way < (2652*0.20) Return true Force
	When Raises = 0 And f$EffectiveMzone <= 10 And f$HandRank2Way < (2652*0.17) Return true Force
	When f$EffectiveMzone <= 6 And f$HandRank2Way < (2652*0.22) Return true Force
	When f$EffectiveMzone <= 4 And f$HandRank2Way < (2652*0.287) Return true Force
	
##f$FinalTableSet##
When mtt_players_remaining > 10 Return false Force
When StackSize < (MinOpponentStackSize * 0.70) And f$RedZone Return false Force
When nplayersseated <= 2 Return false Force
When mtt_players_remaining > 0 And mtt_players_remaining <= nchairs Return true Force
When isfinaltable Return true Force
// If your table map does not recognise the final table you can press f2
// to force final table play
When f2 Return true Force
//
// You can add more conditions here as you wish

##f$FinalTablePlay##
//////////////////////////////////////////////////////////////////////////////////////
// 										Final Table
//////////////////////////////////////////////////////////////////////////////////////
//
// FinalTablePlay 
// Not as loose or aggressive as normal play
// It is fairly basic please modify to suit your own needs...
//
// Second Actions
// Very basic starter you need to work on this...
When Not f$FirstAction And listCat2 RaiseMax Force
When BotsLastAction = Raise And listCat3 RaisePot Force

// A short stack is attempting a re-steal
When (StackSize-AmountToCall) >= 14 And BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 6 RaiseMax Force
When (StackSize-AmountToCall) >= 14 And BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 8 And f$HandRank2Way < (2652*0.180) RaiseMax Force
When (StackSize-AmountToCall) >= 14 And BotsLastAction = Raise And f$OpponentsExcludingSitOuts <= 1 And (AmountToCall + StackSize_raischair) <= 12.5 And f$HandRank2Way < (2652*0.155) RaiseMax Force

When BotsLastAction = Raise And f$HandRank_Playability_General < (2652*0.09) And AmountToCall <= 15% StackSize Call Force
When BotsLastAction = Raise And AmountToCall <= 6% StackSize Call Force
When BotsLastAction = Raise And listCat4 And AmountToCall <= 50% StackSize And Opponents <= (1 + CallsSinceLastRaise) Call Force
When (BotsLastAction = Raise Or BotsLastAction = Call) And AmountToCall <= 2.5 Call Force
When BotsLastAction = Raise Fold Force

// Calling all-ins with premium hands
// An over cautious example you need to change this...
When f$OpponentSignificantAllin And f$FirstAction
	When listCat1 And (CallsSinceLastRaise > 0 Or Raises > 1) RaiseMax Force
	When listCat2 And Raises <= 1 RaisePot Force
	// Get out of the multi-way all in unless very short stacked 
	When (CallsSinceLastRaise > 1 Or Raises > 1) Fold Force
	When listCat5 And AmountToCall <= 5 RaisePot Force
	When listCat5 And AmountToCall < (StackSize * 0.125) Call Force
	When StackSize > 12 Fold Force

When f$FirstAction
	When f$ICM_BootCamp_Push RaiseMax Force
	When f$ICM_BootCamp_Call RaiseMax Force
	When StackSize <= 14 And f$HandRank2Way < (2652*f$Trish_SS_Log) RaiseMax Force

	
// \\ Shortstack Repush \\ //

// Not in a blind \\
When Raises <= 1 And f$FirstAction And Not InTheBlinds And StackSize <= 14
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPnotblindEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 8 And listRPnotblindEP8 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPnotblindMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 9 And listRPnotblindMP9 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPnotblindMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4  And StackSize <= 5 And listRPnotblindMP5 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.15) RaiseMax Force
	When LastRaiserPosition <= 3 And listRPnotblindCO13 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 11 And listRPnotblindCO11 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 9 And listRPnotblindCO9 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 7 And listRPnotblindCO7 RaiseMax Force
	When LastRaiserPosition <= 3 And StackSize <= 6 And listRPnotblindCO6 RaiseMax Force

// In small blind \\
When Raises <= 1 And f$FirstAction And InSmallBlind And StackSize <= 14
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPsbEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 8 And listRPsbEP9 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPsbMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 7 And listRPsbMP7 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPsbMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 4 And listRPsbMP4 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And CallsSinceLastRaise = 0 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.22) RaiseMax Force
	When LastRaiserPosition = 3 And listRPsbCO13 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 11 And listRPsbCO11 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 8 And listRPsbCO8 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 5 And listRPsbCO5 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 4 And listRPsbCO4 RaiseMax Force
	// Vs BU 
	When LastRaiserPosition <= 2 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.28) RaiseMax Force
	When LastRaiserPosition <= 2 And listRPsbBU13 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 10 And listRPsbBU10 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 8 And listRPsbBU8 RaiseMax Force
	When LastRaiserPosition <= 2 And StackSize <= 6 And listRPsbBU6 RaiseMax Force

// In Big blind \\
When Raises <= 1 And f$FirstAction And InBigBlind And StackSize <= 14
	// Vs EP 
	When LastRaiserPosition >= 7 And listRPbbEP13 RaiseMax Force
	When LastRaiserPosition >= 7 And StackSize <= 10 And listRPbbEP10 RaiseMax Force
	// Vs MP 
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And listRPbbMP13 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 8 And listRPbbMP8 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 7 And listRPbbMP7 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 6 And listRPbbMP6 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 5 And listRPbbMP5 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 4 And listRPbbMP4 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 3 And listRPbbMP3 RaiseMax Force
	When LastRaiserPosition < 7 And LastRaiserPosition >= 4 And StackSize <= 2 And listRPbbMP2 RaiseMax Force
	// Vs CO 
	When LastRaiserPosition = 3 And CallsSinceLastRaise = 0 And BetSize <= 3 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.22) RaiseMax Force
	When LastRaiserPosition = 3 And listRPbbCO13 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 10 And listRPbbCO10 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 8 And listRPbbCO8 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 6 And listRPbbCO6 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 5 And listRPbbCO5 RaiseMax Force
	When LastRaiserPosition = 3 And StackSize <= 4 And listRPbbCO4 RaiseMax Force
	// Vs BU 
	When LastRaiserPosition <= 2 And CallsSinceLastRaise = 0 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.28) RaiseMax Force
	When LastRaiserPosition = 2 And listRPsbBU13 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 10 And listRPbbBU10 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 8 And listRPbbBU8 RaiseMax Force
	When LastRaiserPosition = 2 And StackSize <= 6 And listRPbbBU6 RaiseMax Force
	// Vs SB 
	When LastRaiserPosition <= 1 And BetSize <= 3.5 And currentbet_raischair < (balance_raischair * 0.333) And f$HandRank2Way < (2652*0.36) RaiseMax Force
	When LastRaiserPosition <= 1 And listRPbbSB13 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 10 And listRPbbSB10 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 8 And listRPbbSB8 RaiseMax Force
	When LastRaiserPosition <= 1 And StackSize <= 7 And listRPbbSB7 RaiseMax Force
	
When f$FirstAction
	// Basic 3Bet \\ You should improve this
	When f$BootCamp3Bet != 0 And log$FinalTable_3Bet Return f$BootCamp3Bet Force
	When StackSize <= 14 And log$ShortStack_Fold Fold Force
 
// Opening and raising limpers again over simple
// You can replace handrank with lists as you wish
// Or change the percentages for more tight or loose
// 0.125 is 12.5% -- 0.330 is 33% 

When f$FirstAction and Raises = 0 && f$ShortStacksPlaying > 0 
	When InEarlyPosition1 And f$HandRank2Way < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank2Way < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank2Way < (2652 * 0.125) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank2Way < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank2Way < (2652 * 0.180) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank2Way < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank2Way < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank2Way < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank2Way < (2652 * 0.180) RaiseTo (2.5 + Calls) Force
	
When f$FirstAction And Raises = 0 And Calls = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo 3 Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.105) RaiseTo 3 Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.110) RaiseTo 3 Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.125) RaiseTo 3 Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo 3 Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo 2.5 Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.260) RaiseTo 2.5 Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.360) Raise Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.360) RaiseTo 3 Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo 3 Force	
	
When f$FirstAction And  Raises = 0
	When InEarlyPosition1 And f$HandRank_Playability_General < (2652 * 0.090) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition2 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InEarlyPosition3 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition1 And f$HandRank_Playability_General < (2652 * 0.100) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition2 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InMiddlePosition3 And f$HandRank_Playability_General < (2652 * 0.145) RaiseTo (2.5 + Calls) Force
	When InCutOff And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InButton And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2 + Calls) Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.200) And Calls > 0 RaiseTo (2.5 + Calls) Force
	When InSmallBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo 3 Force
	When InBigBlind And FirstCallerPosition > 3 And f$HandRank_Playability_General < (2652 * 0.155) RaiseTo (2.5 + Calls) Force
	When InBigBlind And f$HandRank_Playability_General < (2652 * 0.200) RaiseTo (2.5 + Calls) Force
When Others

// Calling and limping if we have not raised
// Improved from last version but still needs work

When f$FirstAction And AmountToCall > 2
	// Fold hands you don't want to play multiway raised
	//	It is covered above but just in case you delete that
	//	change the list for your own style
	When Raises > 1 And Not listCat2 Fold Force
	// Fold hands you don't want to play in large pots
	//	change the lists and BetSize for your own style
	when BetSize > 8 And Not listCat2 Fold Force
	When BetSize > 5 And Not listCallTight Fold Force
 
When f$FirstAction And InSmallBlind 
	// Call standard raises 
	//	Change the list and BetSize for your own style
	When BetSize < 3.5 And Calls > 1 And listCallSBFT Call Force
	When BetSize < 3.5 And (Calls > 0 Or Raises = 1) And listCallSBFT Call Force
	// Hands you would open limp, uncomment the next line if you wish to limp in
	// When (Calls + Raises = 0) And listLimpStd Call Force

When f$FirstAction And InLatePosition 
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 3.5 And FirstRaiserPosition >= 5 And listCallMedium Call Force
	When BetSize < 3.5 And FirstRaiserPosition < 5 And (Calls > 0 Or Raises = 1) And listCallLoose Call Force
	// Hands you would open limp, comment out the next line if you don't like limping in
	When (Calls + Raises = 0) And listLimpStd Call Force
	
// When f$FirstAction And InMiddlePosition
	// 	A block for middle positions could be added here if you like
	
When f$FirstAction And (InEarlyPosition Or InMiddlePosition)
	// Call standard raises 
	//	Change the lists and BetSize for your own style	
	When BetSize < 3.5 And (Calls > 0 Or Raises = 1) And listCallMedium Call Force
	// Hands you would open limp, uncomment the next line if you wish to limp in
	// When (Calls + Raises = 0) And listLimpMid Call Force
	
When f$FirstAction And InBigBlind And AmountToCall > 0
	// AmountToCall not needed in above line but it short-cuts 
	//	reading the next 3 lines for unopened pots	
	When BetSize < 3.5 And listCallMedium Call Force
	When BetSize < 2.4 And listCallBBA Call Force
	When BetSize < 1.4 And listCallBB Call Force
When Others

When Others Fold Force

##f$ShortStacksPlaying##
((opponentsplayingbits & opponentsactivebits & 0b0000000001) > 0 And (balance0 + currentbet0) >= (bblind*3) And (balance0 + currentbet0) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0000000010) > 0 And (balance1 + currentbet1) >= (bblind*3) And (balance1 + currentbet1) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0000000100) > 0 And (balance2 + currentbet2) >= (bblind*3) And (balance2 + currentbet2) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0000001000) > 0 And (balance3 + currentbet3) >= (bblind*3) And (balance3 + currentbet3) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0000010000) > 0 And (balance4 + currentbet4) >= (bblind*3) And (balance4 + currentbet4) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0000100000) > 0 And (balance5 + currentbet5) >= (bblind*3) And (balance5 + currentbet5) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0001000000) > 0 And (balance6 + currentbet6) >= (bblind*3) And (balance6 + currentbet6) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0010000000) > 0 And (balance7 + currentbet7) >= (bblind*3) And (balance7 + currentbet7) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b0100000000) > 0 And (balance8 + currentbet8) >= (bblind*3) And (balance8 + currentbet8) <= (bblind*12) ? 1 : 0 ) +
((opponentsplayingbits & opponentsactivebits & 0b1000000000) > 0 And (balance9 + currentbet9) >= (bblind*3) And (balance9 + currentbet9) <= (bblind*12) ? 1 : 0 ) +
0


##f$flop_raise_initiative##
//////////////////////////////////////////////////////////////
/////////////////////////////////////       // Gecko Tweaks \\
//////////////////////////////////////////////////////////////
// Notes:
// Changing the hands we play in functions like the ones below
// is as simple as changing the f$prwin percentage EG
// f$prwin > 0.38 to f$prwin > 0.32 more loose, or f$prwin > 0.42 more tight
//
// If you prefer OPPL hand strength symbols change f$prwin > 0.32 EG
// f$PlayersExcludingSitOuts<=2  ? f$prwin > 0.32 : To
// f$PlayersExcludingSitOuts<=2 And (HavePair Or HaveFlushDraw Or HaveStraightDraw Or Have OverPair Or HaveBestOverPairOrBetter) ? 1 :
//
// Or mix and match for more precision
// f$actionpostflop_free_to_play ? {
	// HaveOverPair Or HaveTopPair And f$prwin > 0.45 ? 1 :
	// HaveFlushDraw And nsuitedcommon < 3 ? 1 : 
	// HaveFlushDraw And f$PlayersExcludingSitOuts = 2 And srankhiplayer > 11 ? 1 :
	// HaveFlushDraw And srankhiplayer = 14 ? 1 :
	// HaveStraightDraw And nsuitedcommon < 2 ? 1 :
	//f$draws >= 2 ? 1 :
	// And so on.....
//
// Lots of comments and helpful information is included in the flop section
// I wont include as much for turn or river as if you understand the
// structure for the flop those are very similar
//
//
//
//////////////////////////////////////////////////////////////
//			Raising -- Flop We Are The Aggressor  -- Raising
//////////////////////////////////////////////////////////////	
//
//////////////////////
// In first position
//////////////////////
 Position = First  ? {
	// Hands we will c-bet
    f$actionpostflop_free_to_play  ? {
		//***** C-Bet any overpair above 99 *****\\
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		//***** C-Bet any top pair above 99 *****\\ ??
		HaveTopPair And rankhicommon > 9 ? 1 : 
		//
         f$PlayersExcludingSitOuts<=2  ? f$prwin > 0.32 :
         f$PlayersExcludingSitOuts==3  ? f$prwin > 0.38 :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.45 : 0 } :
	// Raise Vs donk min bet 
    f$actionpostflop_opponent_min_bets  ? {
         f$PlayersExcludingSitOuts<=2  ? f$prwin>0.45 :
         f$PlayersExcludingSitOuts==3  ? f$prwin>0.68 :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.70 : 0 } :
	// Raise Vs other donk bets
     f$actionpostflop_opponent_bets_medium  ? {
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		HaveTopPair And rankhicommon > 10 ? 1 : 
        nplayersplaying==2 ? f$prwin > 0.82 AND f$prwin < 0.950 : // Slow play great hands
        nplayersplaying>=3 ? f$prwin > 0.82 : 0 } :
     f$actionpostflop_opponent_bets_pot  ? f$prwin > 0.840 :
     f$actionpostflop_opponent_overbets  ? f$prwin > 0.860 :
	// Raise if our C-Bet is re-raised
    f$actionpostflop_opponent_min_reraises  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.78 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? {
             f$PlayersExcludingSitOuts==2  ? f$prwin2>.72 : 
             f$PlayersExcludingSitOuts>=3  ? f$prwin2>.78 : 0 } : 0 } :
    f$actionpostflop_opponent_reraises_normal  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.78 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? {
             f$PlayersExcludingSitOuts==2  ? f$prwin2>.76 : 
             f$PlayersExcludingSitOuts>=3  ? f$prwin2>.78 : 0 } : 0 } :
    f$actionpostflop_opponent_reraises_huge  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.78 :
         f$ptype_raise_contibet_high  ? f$prwin2>.77 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.77 : 0 } :
    f$actionpostflop_medium_investment  ? f$prwin>.85 :
    f$actionpostflop_large_investment ? f$prwin>.85 : 0 } :
//////////////////////
// In middle position
//////////////////////
 Position = Middle  ? {
     f$actionpostflop_free_to_play  ? {
	 // Hands we will c-bet
		//***** C-Bet any overpair above 99 *****\\
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		//***** C-Bet any top pair above 99 *****\\ ??
		HaveTopPair And rankhicommon > 9 ? 1 : 
		//
         f$PlayersExcludingSitOuts==2  ? f$prwin > 0.32 :
         f$PlayersExcludingSitOuts==3  ? {
             f$draws>1 AND HaveFlushDraw  ? 1 :
             f$prwin>0.65             ? 1 : 0 } :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.58 : 0 } :
	// Raise Vs donk min bet
     f$actionpostflop_opponent_min_bets  ? {
         f$PlayersExcludingSitOuts==3  ? f$prwin>0.65 :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.65 : 0 } :
	// Raise Vs other donk bets
     f$actionpostflop_opponent_bets_medium  ? {
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		HaveTopPair And rankhicommon > 10 ? 1 : 
        nplayersplaying==2 ? f$prwin > 0.82 AND f$prwin < 0.950 : // Slow play great hands
        nplayersplaying>=3 ? f$prwin > 0.82 : 0 } :
     f$actionpostflop_opponent_bets_pot  ? f$prwin > 0.840 :
     f$actionpostflop_opponent_overbets  ? f$prwin > 0.860 :
	 // Raise if our C-Bet is re-raised
     f$actionpostflop_opponent_min_reraises  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.78 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.78 : 0 } :
     f$actionpostflop_opponent_reraises_normal  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.78 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.78 : 0 } :
     f$actionpostflop_opponent_reraises_huge  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.82 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.80 :
         f$ptype_raise_contibet_high  ? f$prwin2>.80 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.80 : 0 } :
     f$actionpostflop_medium_investment  ? f$prwin>.85 :
     f$actionpostflop_large_investment ? f$prwin>.85 : 0 } :
//////////////////////
// In Last position
//////////////////////
 Position = Last  ? {
     f$actionpostflop_free_to_play  ? {
	 // Hands we will c-bet
	 	//***** C-Bet any overpair above 99 *****\\
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		//***** C-Bet any top pair above 99 *****\\ ??
		HaveTopPair And rankhicommon > 9 ? 1 : 
		//
         f$PlayersExcludingSitOuts<=2  ? f$prwin > 0.32 :
         f$PlayersExcludingSitOuts==3  ? f$prwin > 0.38 :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.65 : 0 } :
	// Raise Vs donk min bet
     f$actionpostflop_opponent_min_bets  ? {
         f$PlayersExcludingSitOuts<=2  ? f$prwin>0.30 :
         f$PlayersExcludingSitOuts==3  ? f$prwin>0.65 :
         f$PlayersExcludingSitOuts>=4  ? f$prwin>0.70 : 0 } :
	// Raise Vs other donk bets
     f$actionpostflop_opponent_bets_medium  ? {
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		HaveTopPair And rankhicommon > 10 ? 1 : 
        nplayersplaying==2 ? f$prwin > 0.82 AND f$prwin < 0.950 : // Slow play great hands
        nplayersplaying>=3 ? f$prwin > 0.82 : 0 } :
     f$actionpostflop_opponent_bets_pot  ? f$prwin > 0.840 :
     f$actionpostflop_opponent_overbets  ? f$prwin > 0.860 :
	 // Raise if our C-Bet is re-raised
     f$actionpostflop_opponent_min_reraises  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.83 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.79 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.77 : 0 } :
     f$actionpostflop_opponent_reraises_normal  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.83 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.79 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78 :
         f$ptype_raise_contibet_very_high      ? f$prwin2>.77 : 0 } :
     f$actionpostflop_opponent_reraises_huge  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.85 :
         f$ptype_raise_contibet_low      ? f$prwin2>.83 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.80 :
         f$ptype_raise_contibet_high  ? f$prwin2>.78:
         f$ptype_raise_contibet_very_high      ? f$prwin2>.78 : 0 } :
     f$actionpostflop_medium_investment  ? f$prwin>.85 :
     f$actionpostflop_large_investment ? f$prwin>.85 : 0 } :
0


##f$flop_call_initiative##
//////////////////////////////////////////////////////////////
//			Calling -- Flop We Are The Aggressor  -- Calling
//////////////////////////////////////////////////////////////	
//
//////////////////////
// In first position
//////////////////////
 Position = First  ? {
	// Call Vs donk bets
     f$actionpostflop_opponent_min_bets  ? f$prwin1>.32 :
     f$actionpostflop_opponent_bets_medium  ? f$prwin1>.65 :
     f$actionpostflop_opponent_bets_pot  ? f$prwin1>.70 :
     f$actionpostflop_opponent_overbets  ? f$prwin1>.75 :
	 // Call when C-Bet is Re-raised
     f$actionpostflop_opponent_min_reraises  ? {
         f$ptype_raise_contibet_very_low  ? f$prwin2>.80 :
         f$ptype_raise_contibet_low      ? f$prwin2>.78 :
         f$ptype_raise_contibet_normal      ? f$prwin2>.75 :
         f$ptype_raise_contibet_high  ? f$prwin2>.72 :
