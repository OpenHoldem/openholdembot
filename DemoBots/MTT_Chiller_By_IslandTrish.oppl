##f$flop_call##
WHEN f$Odds_and_Outs      RETURN true FORCE
WHEN f$Initiative_Hero    RETURN f$flop_call_initiative FORCE
WHEN f$Initiative_Villain RETURN f$flop_call_noinitiative FORCE
WHEN f$Initiative_Nobody  RETURN f$flop_call_noaction FORCE
WHEN f$Initiative_GotRaised Return f$flop_call_wegotraised FORCE

##f$turn_call##
WHEN f$Odds_and_Outs        RETURN true FORCE
WHEN f$Initiative_Hero      RETURN f$turn_call_initiative FORCE
WHEN f$Initiative_Villain   RETURN f$turn_call_noinitiative FORCE
WHEN f$Initiative_Nobody    RETURN f$turn_call_noaction FORCE
WHEN f$Initiative_GotRaised RETURN f$turn_call_wegotraised FORCE

##f$river_call##
WHEN f$Initiative_Hero      RETURN f$river_call_initiative FORCE
WHEN f$Initiative_Villain   RETURN f$river_call_noinitiative FORCE
WHEN f$Initiative_Nobody    RETURN f$river_call_noaction FORCE
WHEN f$Initiative_GotRaised RETURN f$river_call_wegotraised FORCE

##f$flop_raise##
WHEN f$Initiative_Hero    RETURN f$flop_raise_initiative FORCE
WHEN f$Initiative_Villain RETURN f$flop_raise_noinitiative FORCE
WHEN f$Initiative_Nobody  RETURN f$flop_raise_noaction FORCE
WHEN f$Initiative_GotRaised Return f$flop_raise_wegotraised FORCE

##f$turn_raise##
WHEN f$Initiative_Hero      RETURN f$turn_raise_initiative FORCE
WHEN f$Initiative_Villain   RETURN f$turn_raise_noinitiative FORCE
WHEN f$Initiative_Nobody    RETURN f$turn_raise_noaction FORCE
WHEN f$Initiative_GotRaised RETURN f$turn_raise_wegotraised FORCE

##f$river_raise##
WHEN f$Initiative_Hero      RETURN f$river_raise_initiative FORCE
WHEN f$Initiative_Villain   RETURN f$river_raise_noinitiative FORCE
WHEN f$Initiative_Nobody    RETURN f$river_raise_noaction FORCE
WHEN f$Initiative_GotRaised RETURN f$river_raise_wegotraised FORCE

##f$Initiative_Hero##
// Can't have initiative preflop: either we did not yet act or somebody raised
WHEN IsPreflop RETURN false FORCE
When f$Initiative_GotRaised Return false Force
//WHEN didcallround_previousround RETURN false FORCE
WHEN didbetsizeround_previousround OR didraisround_previousround RETURN true FORCE

##f$Initiative_Nobody##
NOT f$Initiative_Hero AND NOT f$Initiative_Villain And Not f$Initiative_GotRaised

##f$Initiative_Villain##
f$Initiative_GotRaised ? 0 :
IsPreflop && ncallbets > 1 ? 1 :
IsFlop && (didcallround_previousround && nbetsround_preflop > 1) ? 1 :
(betround > 2) && didcallround_previousround && (nbetsround_previousround > 0) ? 1 :
0

##f$Initiative_GotRaised_Calc##
lastraised_previousround < 0 ? 0 :
BotsActionsOnThisRoundIncludingChecks > 0 ? 0 :
(!didbetsizeround_previousround && !didraisround_previousround) ? 0 :
!didcallround_previousround ? 0 :
prevaction = 1 ? 1 :
0

##f$Initiative_GotRaised##
me_re_initiativegotraised = 1 ? 1 :
f$Initiative_GotRaised_Calc And me_st_initiativegotraised_1 >= 0 ? 1 :
0

##f$ini_function_on_new_round##
me_st_initiativegotraised_0

##f$allin_on_betsize_balance_ratio##
// Not present in Geckos original bot for OpenHoldem 2.x,
// His code suggests that he wanted it to be 0.66,
// but as Gecko used raise-by-semantics and we use raise-to
// about 0.50 looks like a more appropriate value,
// firther improving it to 40% OOP,
// Fail-safe for mis-scraped stacks
WHEN (StackSize <= 0) RETURN 0.00 FORCE
// Push if short stacked in tournaments for any significant bet size
When f$EffectiveActiveStackInBigBlinds <= 10 Return 0.020 Force
WHEN NOT HandIsHeadsup RETURN f$positional_allin_on_betsize_balance_ratio FORCE
// Sole opponent already allin or mis-scraped opponents stack
WHEN (StackSize_headsupchair <= 0) RETURN f$positional_allin_on_betsize_balance_ratio FORCE
// Opponents stack larger than ours: normal behaviour
WHEN (StackSize_headsupchair >= StackSize) RETURN f$positional_allin_on_betsize_balance_ratio FORCE
// Single opponent with smaller stack.
// Go more lightly allin if our bet is more than 50% of his stack.
WHEN Others RETURN (f$positional_allin_on_betsize_balance_ratio * (StackSize_headsupchair / StackSize)) FORCE

##f$Trish_SS_Start##
Raises = 0 And f$FinalTableSet And StackSize >= 8 ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 12 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 23.4 :
	InButton ? 23.4 :
	InSmallBlind ? 23.4 :
	InBigBlind ? 23.4 :
	23.4 } : 	

Raises + Calls = 0 And StackSize <= 20 ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 10.4 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 30 :
	InButton ? 34 :
	InSmallBlind ? 45.2 :
	30 } : 
Raises + Calls = 0 ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 12 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 23.4 :
	InButton ? 28.1 :
	InSmallBlind ? 28.1 :
	23.4 } : 
Raises = 0 And (StackSize <= 14 Or f$RedZone) ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 12 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 23.4 :
	InButton ? 23.4 :
	InSmallBlind ? 23.4 :
	InBigBlind ? 23.4 :
	23.4 } : 
Raises = 0 And Calls <= 1 ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 12 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 19.5 :
	InButton ? 19.5 :
	InSmallBlind ? 19.4 :
	InBigBlind ? 19.4 :
	23.4 } : 	
Raises = 0 ? {
	InEarlyPosition1 ? 11 :
	InEarlyPosition2 ? 11 :
	InEarlyPosition3 ? 11 :
	InMiddlePosition1 ? 12 :
	InMiddlePosition2 ? 13.7 :
	InMiddlePosition3 ? 16.7 :
	InCutOff ? 16.4 :
	InButton ? 16.4 :
	InSmallBlind ? 16.4 :
	InBigBlind ? 16.4 :
	16.4 } : 	
16.7
##f$Trish_SS_Stop##
Raises = 0 And f$FinalTableSet And StackSize >= 8 ? {
	InEarlyPosition1 ? 29 :
	InEarlyPosition2 ? 29 :
	InEarlyPosition3 ? 29 :
	InMiddlePosition1 ? 40 :
	InMiddlePosition2 ? 40 :
	InMiddlePosition3 ? 40 :
	InCutOff ? 40 :
	InButton ? 40 :
	InSmallBlind ? 40 :
	40 } : 

Raises = 0 ? {
	InEarlyPosition1 ? 29 :
	InEarlyPosition2 ? 29 :
	InEarlyPosition3 ? 29 :
	InMiddlePosition1 ? 40 :
	InMiddlePosition2 ? 40 :
	InMiddlePosition3 ? 40 :
	InCutOff ? 50 :
	InButton ? 56 :
	InSmallBlind ? 66 :
	75 } : 
40
##f$Trish_SS_Exponent##
(ln (f$Trish_SS_Stop / f$Trish_SS_Start) / 11)*(15 - StackSize)

##f$Trish_SS_Log##
Raises > 0 ? 0 :
StackSize > 15 ? (f$Trish_SS_Start/100) :
StackSize <= 3 ? 0.75 :
StackSize <= 2 ? 1 :
f$Trish_SS_Start*(2.718281828459**(f$Trish_SS_Exponent)) < f$Trish_SS_Start ? (f$Trish_SS_Start/100) :
f$Trish_SS_Start*(2.718281828459**(f$Trish_SS_Exponent)) > f$Trish_SS_Stop ? (f$Trish_SS_Stop/100) :
f$Trish_SS_Start*(2.718281828459**(f$Trish_SS_Exponent))/100
	
///////////////////////////////////////////////////////////////////

##f$ProbabilityOpponentHasHigherPockets##
// This is approximate but close enough
Not ispair ? 45 :
rankhiplayer >= 10 ? (f$OpponentsExcludingSitOuts * (14-rankhiplayer)) / 2 :
(nopponentsseated * (14-rankhiplayer)) / 2 

##f$PlayersExcludingSitOuts##
BitCount (playersactivebits & playersplayingbits)

##f$OpponentsExcludingSitOuts##
BitCount (opponentsactivebits & opponentsplayingbits)

##f$delay##
// Rendom delay of 0..3000 milli-seconds
title$DD And title$Poker ? 0 :
Random * 30

##f$check##
1

