     f$actionpostflop_medium_investment  ?  f$prwin1 > 0.95 :
     f$actionpostflop_large_investment ?  f$prwin1 > 0.96 : 0 } :
0

##f$flop_raise_wegotraised##
 Position = First  ? {
     f$PlayersExcludingSitOuts==2  ? {
     f$actionpostflop_free_to_play  ?  f$prwin1 > 0.80 :
     f$actionpostflop_opponent_min_bets  ?  f$prwin1 > 0.80 :
     f$actionpostflop_opponent_bets_medium  ?  f$prwin1 > 0.85 :
     f$actionpostflop_opponent_bets_pot  ?  f$prwin1 > 0.85 :
