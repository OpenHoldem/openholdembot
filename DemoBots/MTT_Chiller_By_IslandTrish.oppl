     f$actionpostflop_medium_investment  ? f$nuts      :
     f$actionpostflop_large_investment ? f$nuts      : 0 } : 0 } :
 Position = Middle  ? {
     f$actionpostflop_free_to_play  ?  f$prwin1 > 0.96 :
     f$actionpostflop_opponent_min_bets  ?  f$prwin1 > 0.90 :
     f$actionpostflop_opponent_bets_medium  ?  f$prwin1 > 0.96 :
     f$actionpostflop_opponent_bets_pot  ?  f$prwin1 > 0.96 :
