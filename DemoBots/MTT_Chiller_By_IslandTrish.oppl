     f$actionpostflop_opponent_reraises_normal  ?  f$prwin1 > 0.97 :
     f$actionpostflop_opponent_reraises_huge  ?  f$prwin1 > 0.98 :
     f$actionpostflop_medium_investment  ? f$nuts      :
     f$actionpostflop_large_investment ? f$nuts      : 0 } :
     f$PlayersExcludingSitOuts>=3  ? {
     f$actionpostflop_free_to_play  ?  f$prwin1 > 0.80 :
