##f$turn_raise_initiative##
//////////////////////////////////////////////////////////////
//			Raising -- Turn We Are The aggressor  -- Raising
//////////////////////////////////////////////////////////////
// Lots of comments and helpful information is included in the flop section
// I wont include as much for turn or river as if you understand the
// structure for the flop those are very similar.
//
 Position = First  ? {
     f$actionpostflop_free_to_play  ? {
		nsuitedcommon < 4 And nstraightfill > 1 And ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		nsuitedcommon < 4 And nstraightfill > 1 And HaveTopPair And rankhicommon > 9 ? 1 : 
        f$PlayersExcludingSitOuts==2 AND nplayersround_flop==2  ? {
             didcallround_preflop AND nbetsround_preflop>1 AND nbetsround_preflop<=5  ? f$prwin>0.28 : // donkbet and 2nd barrel turn
             f$AggressionFactor_Turn2<=3.00  ? {
                 f$draws>1    ? 1 :
                 f$prwin>.70 AND NOT(ismidpair AND (rankhicommon == ace) AND NOT PairOnBoard)  ? 1 : 0 } :
             f$AggressionFactor_Turn2>3.00 AND NOT(ismidpair AND (rankhicommon == ace) AND NOT PairOnBoard)  ? f$prwin>.70 AND f$prwin<.80 : 0 } : // only barrel value oop
         f$PlayersExcludingSitOuts>=2 AND nplayersround_flop>=3 AND NOT(ismidpair AND (rankhicommon == ace) AND NOT PairOnBoard)  ? f$prwin>.74 : 0 } :
		 
     f$actionpostflop_opponent_min_bets  ? f$prwin>.80 :
	 f$actionpostflop_opponent_bets_medium And nstraightfillcommon > 1 And nsuitedcommon < 4 And HaveTopPair ? 1 :
	 f$actionpostflop_opponent_bets_medium  ? f$prwin > 0.850 :
     f$actionpostflop_opponent_bets_pot  ? f$prwin>.90 : // check push allin
     f$actionpostflop_opponent_overbets  ? f$prwin>.90 :
     f$actionpostflop_opponent_min_reraises  ? f$prwin>.85 :
     f$actionpostflop_opponent_reraises_normal  ? f$prwin>.90 :
     f$actionpostflop_opponent_reraises_huge  ? f$prwin>.97 :
     f$actionpostflop_medium_investment  ? f$nuts      :
     f$actionpostflop_large_investment ? f$nuts      : 0 } :
 Position = Middle  ? {
	f$actionpostflop_free_to_play And nsuitedcommon < 3 And nstraightfill > 2 And  ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
	f$actionpostflop_free_to_play And nsuitedcommon < 3 And nstraightfill > 2 And  HaveTopPair And rankhicommon > 9 ? 1 : 
     f$actionpostflop_free_to_play  ? f$prwin>.72 :
     f$actionpostflop_opponent_min_bets  ? f$prwin>.80 :
	 f$actionpostflop_opponent_bets_medium And nstraightfillcommon > 1 And nsuitedcommon < 4 And HaveTopPair ? 1 :
	f$actionpostflop_opponent_bets_medium  ? f$prwin > 0.850 :
     f$actionpostflop_opponent_bets_pot  ? f$prwin>.90 :
     f$actionpostflop_opponent_overbets  ? f$prwin>.95 :
     f$actionpostflop_opponent_min_reraises  ? f$prwin>.96 :
     f$actionpostflop_opponent_reraises_normal  ? f$prwin>.96 :
     f$actionpostflop_opponent_reraises_huge  ? f$prwin>.97 :
     f$actionpostflop_medium_investment  ? f$nuts      :
     f$actionpostflop_large_investment ? f$nuts      : 0 } :
 Position = Last  ? {
     f$actionpostflop_free_to_play  ? {
		nsuitedcommon < 4 And nstraightfill > 1 And ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		nsuitedcommon < 3 And nstraightfill > 2 And HaveTopPair And rankhicommon > 9 ? 1 : 
        f$PlayersExcludingSitOuts==2 AND nplayersround_flop==2  ? {
            f$prwin<0.72 AND NOT (ismidpair AND (rankhicommon == ace) AND NOT PairOnBoard) AND ranklocommon<10 AND nbetsround_preflop<7 AND nbetsround_flop<15 AND NOT PairOnBoard  ? 1 :
            f$prwin>=0.78  ? 1 : 0 } :
         f$PlayersExcludingSitOuts>=2 AND nplayersround_flop>=3 AND ranklocommon<10 AND NOT (ismidpair AND (rankhicommon == ace) AND NOT PairOnBoard)  ? f$prwin>0.65 : 0 } :
     f$actionpostflop_opponent_min_bets  ? f$prwin>.80 :
	 f$actionpostflop_opponent_bets_medium And nstraightfillcommon > 1 And nsuitedcommon < 4 And HaveTopPair ? 1 :
	f$actionpostflop_opponent_bets_medium  ? f$prwin > 0.850 :
     f$actionpostflop_opponent_bets_pot  ? f$prwin>.85 :
     f$actionpostflop_opponent_overbets  ? f$prwin>.95 :
     f$actionpostflop_opponent_min_reraises  ? f$prwin>.96 :
     f$actionpostflop_opponent_reraises_normal  ? f$prwin>.96 :
     f$actionpostflop_opponent_reraises_huge  ? f$prwin>.97 :
     f$actionpostflop_medium_investment  ? f$nuts      :
     f$actionpostflop_large_investment ? f$nuts      : 0 } :
