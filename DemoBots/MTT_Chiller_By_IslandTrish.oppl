##f$flop_raise_noaction##
//////////////////////////////////////////////////////////////
//			Raising -- Flop Nobody Has Initiative  -- Raising
//////////////////////////////////////////////////////////////
//
//////////////////////
// In first position
//////////////////////
 Position = First  ? {
	// Bet first in
	f$actionpostflop_free_to_play  ? {
		ispair And rankhiplayer > rankhicommon And rankhiplayer > 9 ? 1 :
		HaveTopPair And rankhicommon > 9 ? 1 : 
		f$prwin>.55 } :
	 // Raise min bets
     f$actionpostflop_opponent_min_bets  ? f$prwin>.60 :
	 // Raise other bets
